<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#EEF2FF">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TaskMaster"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="#2563EB"
        android:layout_gravity="center"
        android:paddingBottom="20dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Stay productive and finish your goals 🚀"
        android:textSize="16sp"
        android:textColor="#64748B"
        android:layout_gravity="center"
        android:paddingBottom="15dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp">

        <TextView
            android:id="@+id/taskCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📋 Tasks: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#2563EB"/>

        <TextView
            android:id="@+id/completedCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end"
            android:text="✅ Done: 0"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#22C55E"/>

    </LinearLayout>
    <TextView
        android:id="@+id/timeText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00 AM"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2563EB"
        android:layout_gravity="center"/>
    <TextView
        android:id="@+id/dateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textColor="#64748B"
        android:layout_gravity="center"
        android:paddingBottom="15dp"/>

    <EditText
        android:id="@+id/editTask"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:hint="Enter a task..."
        android:textSize="16sp"
        android:padding="15dp"
        android:backgroundTint="#2563EB"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnAdd"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="+ Add Task"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#2563EB"
        android:layout_marginTop="10dp"/>

    <ListView
        android:id="@+id/listViewTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Made by Jiya Baghel ❤️"
        android:textColor="#64748B"
        android:textSize="12sp"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"/>

</LinearLayout>
